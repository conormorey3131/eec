# Google Analytics 4 Measurement ID
# Get this from: Google Analytics > Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL (used for canonical URLs and sitemap)
NEXT_PUBLIC_SITE_URL=https://efficientenergy.ie

# Contact email (will be used for form submissions)
CONTACT_EMAIL=info@eec.ie

# Optional: Email service credentials (when you set up email sending)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
